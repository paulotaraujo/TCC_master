static void recomputeSettings() {
  g_oc51Pickup = I_NOMINAL_RMS * (1.0f + OC_51_PCT / 100.0f);
  g_oc50Pickup = I_NOMINAL_RMS * (1.0f + OC_50_PCT / 100.0f);
  g_oc51Dropout = 0.95f * g_oc51Pickup;

  g_distZ1Ohm = DIST_LINE_Z_OHM * (DIST_Z1_PCT / 100.0f);
  g_distZ2Ohm = DIST_LINE_Z_OHM * (DIST_Z2_PCT / 100.0f);
  g_distZ2DropoutOhm = 1.05f * g_distZ2Ohm;
  DIST_MIN_CURRENT = 0.05f * I_NOMINAL_RMS;
  g_distZ1Circle = mhoCircle(g_distZ1Ohm, DIST_LINE_ANGLE_DEG);
  g_distZ2Circle = mhoCircle(g_distZ2Ohm, DIST_LINE_ANGLE_DEG);

  g_uvPickup = V_NOMINAL_RMS * (UV_PICKUP_PCT / 100.0f);
  g_uvDropout = 1.03f * g_uvPickup;
  g_ovPickup = V_NOMINAL_RMS * (OV_PICKUP_PCT / 100.0f);
  g_ovDropout = 0.97f * g_ovPickup;
}

static float wrapAngleDeg(float angleDeg) {
  float wrapped = fmodf(angleDeg + 180.0f, 360.0f);
  if (wrapped < 0.0f) wrapped += 360.0f;
  wrapped -= 180.0f;
  if (wrapped == -180.0f) return 180.0f;
  return wrapped;
}

static float adcToVolts(uint16_t adc) {
  return ((float)adc / ADC_MAX) * ADC_VREF;
}

static float autoOutlierStep(float ampPeak, float freqHz, float sampleRateHz) {
  float fs = max(1.0f, sampleRateHz);
  float f = max(1.0f, freqHz);
  float a = max(1.0f, fabsf(ampPeak));
  float maxStep = a * (2.0f * PI * f) / fs;
  return max(0.8f, 6.0f * maxStep);
}

static uint16_t readAdcAvg(int pin, int n) {
  uint32_t acc = 0;
  for (int i = 0; i < n; ++i) acc += analogRead(pin);
  uint32_t avg = acc / (uint32_t)n;
  if (avg > 4095) avg = 4095;
  return (uint16_t)avg;
}

static Phasor fundamentalPhasorRms(const float *samples, uint16_t n) {
  Phasor out;
  if (n < 2) return out;

  float re = 0.0f;
  float im = 0.0f;
  for (uint16_t k = 0; k < n; ++k) {
    float theta = (2.0f * PI * (float)k) / (float)n;
    re += samples[k] * cosf(theta);
    im -= samples[k] * sinf(theta);
  }

  float peakMag = (2.0f / (float)n) * sqrtf(re * re + im * im);
  out.mag = peakMag / sqrtf(2.0f);
  out.angleDeg = wrapAngleDeg(atan2f(im, re) * 180.0f / PI);
  return out;
}

static MhoCircle mhoCircle(float reachOhm, float lineAngleDeg) {
  float angleRad = lineAngleDeg * PI / 180.0f;
  MhoCircle circle;
  circle.radius = 0.5f * reachOhm;
  circle.centerR = circle.radius * cosf(angleRad);
  circle.centerX = circle.radius * sinf(angleRad);
  return circle;
}

static bool mhoOperates(float rOhm, float xOhm, float reachOhm, float lineAngleDeg) {
  MhoCircle c = mhoCircle(reachOhm, lineAngleDeg);
  float dr = rOhm - c.centerR;
  float dx = xOhm - c.centerX;
  return (dr * dr + dx * dx) <= (c.radius * c.radius);
}

static void writeRelay(int pin, bool active) {
  if (RELAY_ACTIVE_LOW) {
    digitalWrite(pin, active ? LOW : HIGH);
  } else {
    digitalWrite(pin, active ? HIGH : LOW);
  }
}

static void updateRelayOutputs() {
  bool z1 = g_distZ1Trip != 0;
  bool z2 = (g_distZ2Active != 0) || (g_distZ2Trip != 0);
  bool enable = (g_distEnableTrip != 0) || z1 || z2;

  writeRelay(RELAY_DIST_BLOCK_PIN, g_distBlockTrip != 0);
  writeRelay(RELAY_DIST_ENABLE_PIN, enable);
  writeRelay(RELAY_DIST_Z1_PIN, z1);
  writeRelay(RELAY_DIST_Z2_PIN, z2);
}

static void updateSystemReadyLed() {
  static bool ledState = false;
  static bool initialized = false;
  static int8_t writtenState = -1;
  static uint32_t lastToggleMs = 0;

  if (g_systemReady) {
    ledState = true;
    initialized = true;
    if (writtenState != HIGH) {
      digitalWrite(LED_SYSTEM_READY_PIN, HIGH);
      writtenState = HIGH;
    }
    return;
  }

  uint32_t nowMs = millis();
  if (!initialized) {
    ledState = true;
    initialized = true;
    lastToggleMs = nowMs;
    if (writtenState != HIGH) {
      digitalWrite(LED_SYSTEM_READY_PIN, HIGH);
      writtenState = HIGH;
    }
    return;
  }

  if (nowMs - lastToggleMs >= SYSTEM_READY_LED_BLINK_INTERVAL_MS) {
    ledState = !ledState;
    lastToggleMs = nowMs;
    int8_t nextState = ledState ? HIGH : LOW;
    if (writtenState != nextState) {
      digitalWrite(LED_SYSTEM_READY_PIN, nextState);
      writtenState = nextState;
    }
  }
}

static bool anyTripLatched() {
  return (g_ocTrip != 0) || (g_oc50Trip != 0) || (g_oc51Trip != 0) ||
         (g_distTrip != 0) || (g_distZ1Trip != 0) || (g_distZ2Trip != 0) ||
         (g_uvTrip != 0) || (g_ovTrip != 0);
}

static void updateTripLed() {
  static bool ledState = false;
  static bool wasTripped = false;
  static int8_t writtenState = -1;
  static uint32_t lastToggleMs = 0;

  if (!anyTripLatched()) {
    if (wasTripped || ledState || writtenState != LOW) {
      ledState = false;
      wasTripped = false;
      lastToggleMs = millis();
      digitalWrite(LED_ANY_TRIP_PIN, LOW);
      writtenState = LOW;
    }
    return;
  }

  uint32_t nowMs = millis();
  if (!wasTripped) {
    ledState = true;
    wasTripped = true;
    lastToggleMs = nowMs;
    if (writtenState != HIGH) {
      digitalWrite(LED_ANY_TRIP_PIN, HIGH);
      writtenState = HIGH;
    }
    return;
  }

  if (nowMs - lastToggleMs >= TRIP_LED_BLINK_INTERVAL_MS) {
    ledState = !ledState;
    lastToggleMs = nowMs;
    int8_t nextState = ledState ? HIGH : LOW;
    if (writtenState != nextState) {
      digitalWrite(LED_ANY_TRIP_PIN, nextState);
      writtenState = nextState;
    }
  }
}

static void testRelayOutputs() {
  bool wasRunning = g_running;
  g_running = false;
  resetTrips();

  Serial.println("TEST_RELAY block");
  writeRelay(RELAY_DIST_BLOCK_PIN, true);
  delay(1200);
  writeRelay(RELAY_DIST_BLOCK_PIN, false);

  Serial.println("TEST_RELAY enable");
  writeRelay(RELAY_DIST_ENABLE_PIN, true);
  delay(1200);
  writeRelay(RELAY_DIST_ENABLE_PIN, false);

  Serial.println("TEST_RELAY z1");
  writeRelay(RELAY_DIST_Z1_PIN, true);
  delay(1200);
  writeRelay(RELAY_DIST_Z1_PIN, false);

  Serial.println("TEST_RELAY z2");
  writeRelay(RELAY_DIST_Z2_PIN, true);
  delay(1200);
  writeRelay(RELAY_DIST_Z2_PIN, false);

  updateRelayOutputs();
  g_running = wasRunning;
  Serial.println("OK testrelays");
}

