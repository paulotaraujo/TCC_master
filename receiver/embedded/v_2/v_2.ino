static void pushLog(const LogRow &row) {
  g_log[g_logHead] = row;
  g_logHead = (uint16_t)((g_logHead + 1) % LOG_CAPACITY);
  if (g_logCount < LOG_CAPACITY) g_logCount++;
}

static void dumpLogCsv() {
  printCsvHeader();
  uint16_t start = (g_logHead + LOG_CAPACITY - g_logCount) % LOG_CAPACITY;
  for (uint16_t i = 0; i < g_logCount; ++i) {
    uint16_t idx = (uint16_t)((start + i) % LOG_CAPACITY);
    printCsvRow(g_log[idx]);
    if ((i % 32) == 0) delay(1);
  }
  Serial.printf("DUMP_DONE rows=%u\n", g_logCount);
}

static void clearLog() {
  g_logHead = 0;
  g_logCount = 0;
}

static float medianSmall(float *values, uint8_t count) {
  for (uint8_t i = 1; i < count; ++i) {
    float key = values[i];
    int j = i - 1;
    while (j >= 0 && values[j] > key) {
      values[j + 1] = values[j];
      j--;
    }
    values[j + 1] = key;
  }
  return values[count / 2];
}

