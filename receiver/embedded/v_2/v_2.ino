static void evaluateProtections(float cycleDtS) {
  bool evalReady = g_fourierValid == 1 && (!NORMALIZE_TO_COMTRADE || g_normReady == 1);

  if (OC_ENABLED && evalReady) {
    if (g_i1Mag >= g_oc50Pickup) {
      g_oc50Trip = 1;
      g_ocTrip = 1;
    }
    if (g_i1Mag >= g_oc51Pickup) {
      g_oc51Active = 1;
      g_oc51Timer += cycleDtS;
      if (g_oc51Timer >= OC_51_DELAY_S) {
        g_oc51Trip = 1;
        g_ocTrip = 1;
      }
    } else if (g_i1Mag < g_oc51Dropout) {
      if (!g_oc51Trip) {
        g_oc51Active = 0;
        g_oc51Timer = 0.0f;
      }
    } else {
      g_oc51Active = 0;
    }
  }

  if (DIST_ENABLED && evalReady && g_i1Mag > max(1e-12f, DIST_MIN_CURRENT)) {
    g_distZMag = g_v1Mag / max(1e-12f, g_i1Mag);
    g_distZAngle = wrapAngleDeg(g_v1Angle - g_i1Angle);
    float angleRad = g_distZAngle * PI / 180.0f;
    g_distR = g_distZMag * cosf(angleRad);
    g_distX = g_distZMag * sinf(angleRad);
    g_distFaultPct = (g_distZMag / DIST_LINE_Z_OHM) * 100.0f;

    bool z1Mho = mhoOperates(g_distR, g_distX, g_distZ1Ohm, DIST_LINE_ANGLE_DEG) && g_distZMag <= g_distZ1Ohm;
    bool z2Mho = mhoOperates(g_distR, g_distX, g_distZ2Ohm, DIST_LINE_ANGLE_DEG) && !z1Mho && g_distZMag <= g_distZ2Ohm;
    bool z2Dropout = mhoOperates(g_distR, g_distX, g_distZ2DropoutOhm, DIST_LINE_ANGLE_DEG);
    bool anyMho = z1Mho || z2Mho;

    bool dirOk = true;
    if (DIR67_ENABLED) {
      g_dir67Power = g_v1Mag * g_i1Mag * cosf((g_v1Angle - g_i1Angle) * PI / 180.0f);
      if (!anyMho && fabsf(g_dir67Power) > DIR67_POWER_MIN_W) {
        g_dir67PrefaultPower = g_dir67Power;
      }
      bool forward = g_dir67PrefaultPower > DIR67_POWER_MIN_W;
      bool reverse = g_dir67PrefaultPower < -DIR67_POWER_MIN_W;
      dirOk = DIR67_FORWARD ? forward : reverse;
    } else {
      g_dir67Power = 0.0f;
      dirOk = true;
    }
    g_dir67Permit = (anyMho && dirOk) ? 1 : 0;

    if (anyMho && !g_dir67Permit) {
      g_dir67BlockActive = 1;
      g_distZ2Timer = 0.0f;
    } else if (z1Mho) {
      g_dir67BlockActive = 0;
      g_distZ1Trip = 1;
      g_distTrip = 1;
    } else if (z2Mho) {
      g_dir67BlockActive = 0;
      g_distZ2Timer += cycleDtS;
      if (g_distZ2Timer >= DIST_Z2_DELAY_S) {
        g_distZ2Trip = 1;
        g_distTrip = 1;
      }
    } else if (!z2Dropout && !g_distZ2Trip) {
      g_distZ2Timer = 0.0f;
      g_dir67BlockActive = 0;
    } else {
      g_dir67BlockActive = 0;
    }
  }

  if ((UV_ENABLED || OV_ENABLED) && evalReady) {
    if (UV_ENABLED) {
      if (g_v1Mag <= g_uvPickup) {
        g_uvTimer += cycleDtS;
        if (g_uvTimer >= UV_DELAY_S) g_uvTrip = 1;
      } else if (g_v1Mag > g_uvDropout && !g_uvTrip) {
        g_uvTimer = 0.0f;
      }
    }
    if (OV_ENABLED) {
      if (g_v1Mag >= g_ovPickup) {
        g_ovTimer += cycleDtS;
        if (g_ovTimer >= OV_DELAY_S) g_ovTrip = 1;
      } else if (g_v1Mag < g_ovDropout && !g_ovTrip) {
        g_ovTimer = 0.0f;
      }
    }
  }

  bool trip = g_ocTrip || g_distTrip || g_uvTrip || g_ovTrip;
  setRelay(trip);
}

static void closeCycle(uint32_t nowUs) {
  if (!g_haveCycleStart) return;

  uint32_t periodUs = nowUs - g_cycleStartUs;
  uint8_t localFlags = g_cycleFlags;
  uint8_t localValid = 1;

  if (g_cycleN < 8) {
    localFlags |= FLAG_INCOMPLETE_CYCLE;
    localValid = 0;
    g_v1Mag = 0.0f;
    g_i1Mag = 0.0f;
    g_v1Angle = 0.0f;
    g_i1Angle = 0.0f;
    g_fEst = 0.0f;
  } else {
    Phasor v1 = fundamentalPhasorRms(g_cycleV, g_cycleN);
    Phasor i1 = fundamentalPhasorRms(g_cycleI, g_cycleN);
    g_v1Mag = v1.mag;
    g_i1Mag = i1.mag;
    g_v1Angle = v1.angleDeg;
    g_i1Angle = i1.angleDeg;
    g_fEst = 1000000.0f / max(1.0f, (float)periodUs);
    if (!(F_MIN_HZ <= g_fEst && g_fEst <= F_MAX_HZ)) {
      localFlags |= FLAG_FREQ_OOR;
      localValid = 0;
    }

    if (NORMALIZE_TO_COMTRADE && localValid == 1) {
      float minVRaw = max(1e-9f, NORM_MIN_PU * V_NOMINAL_RMS);
      float minIRaw = max(1e-9f, NORM_MIN_PU * I_NOMINAL_RMS);
      bool goodForNorm = g_v1Mag >= minVRaw && g_i1Mag >= minIRaw;
      if (!g_normReady && goodForNorm && g_prefaultCount < PREFAULT_CYCLES) {
        g_prefaultV[g_prefaultCount] = g_v1Mag;
        g_prefaultI[g_prefaultCount] = g_i1Mag;
        g_prefaultCount++;
        if (g_prefaultCount >= PREFAULT_CYCLES) {
          float tmpV[PREFAULT_CYCLES];
          float tmpI[PREFAULT_CYCLES];
          for (int i = 0; i < PREFAULT_CYCLES; ++i) {
            tmpV[i] = g_prefaultV[i];
            tmpI[i] = g_prefaultI[i];
          }
          g_normGainV = V_NOMINAL_RMS / max(1e-9f, medianSmall(tmpV, PREFAULT_CYCLES));
          g_normGainI = I_NOMINAL_RMS / max(1e-9f, medianSmall(tmpI, PREFAULT_CYCLES));
          g_normReady = 1;
        }
      }
      if (g_normReady) {
        g_v1Mag *= g_normGainV;
        g_i1Mag *= g_normGainI;
      }
    }
  }

  g_viAngle = wrapAngleDeg(g_i1Angle - g_v1Angle);
  g_fourierValid = localValid;
  g_lastQualityFlags = localFlags;
  evaluateProtections((float)periodUs / 1000000.0f);
  g_cycleId++;
}

static void resetCycle(uint32_t nowUs) {
  g_cycleStartUs = nowUs;
  g_haveCycleStart = true;
  g_cycleN = 0;
  g_cycleSumV2 = 0.0f;
  g_cycleSumI2 = 0.0f;
  g_cycleFlags = 0;
}

static void appendCycleSample(float vInst, float iInst) {
  if (!g_haveCycleStart) return;
  if (g_cycleN < MAX_CYCLE_SAMPLES) {
    g_cycleV[g_cycleN] = vInst;
    g_cycleI[g_cycleN] = iInst;
    g_cycleN++;
  } else {
    g_cycleFlags |= FLAG_INCOMPLETE_CYCLE;
  }
  g_cycleSumV2 += vInst * vInst;
  g_cycleSumI2 += iInst * iInst;
}

static void logSample(uint32_t nowUs, uint16_t adcV, uint16_t adcI, float vInst, float iInst, uint8_t cycleUpdate) {
  LogRow row;
  row.dev_t_s = (float)nowUs / 1000000.0f;
  row.dev_t_us = nowUs;
  row.seq = g_seq;
  row.adc_v = adcV;
  row.adc_i = adcI;
  row.v_inst = vInst;
  row.i_inst = iInst;
  row.v1_mag = g_v1Mag;
  row.i1_mag = g_i1Mag;
  row.v1_angle_deg = g_v1Angle;
  row.i1_angle_deg = g_i1Angle;
  row.vi_angle_deg = g_viAngle;
  row.fourier_valid = g_fourierValid;
  row.f_est_hz = g_fEst;
  row.norm_ready = g_normReady;
  row.norm_gain_v = g_normGainV;
  row.norm_gain_i = g_normGainI;
  row.oc_51_timer_s = g_oc51Timer;
  row.oc_51_active = g_oc51Active;
  row.oc_50_trip = g_oc50Trip;
  row.oc_51_trip = g_oc51Trip;
  row.oc_trip = g_ocTrip;
  row.dist_z_mag_ohm = g_distZMag;
  row.dist_z_angle_deg = g_distZAngle;
  row.dist_r_ohm = g_distR;
  row.dist_x_ohm = g_distX;
  row.dist_fault_pct = g_distFaultPct;
  row.dist_z2_timer_s = g_distZ2Timer;
  row.dist_z1_trip = g_distZ1Trip;
  row.dist_z2_trip = g_distZ2Trip;
  row.dist_trip = g_distTrip;
  row.dir67_power_w = g_dir67Power;
  row.dir67_prefault_power_w = g_dir67PrefaultPower;
  row.dir67_permit = g_dir67Permit;
  row.dir67_block_active = g_dir67BlockActive;
  row.uv_timer_s = g_uvTimer;
  row.ov_timer_s = g_ovTimer;
  row.uv_trip = g_uvTrip;
  row.ov_trip = g_ovTrip;
  row.cycle_id = g_cycleId;
  row.cycle_update = cycleUpdate;
  row.quality_flags = g_lastQualityFlags;

  pushLog(row);
  if (g_streamCycleCsv && cycleUpdate) {
    if (!g_csvHeaderPrinted) printCsvHeader();
    printCsvRow(row);
  }
}

static void processSample() {
  static uint32_t nextUs = 0;
  uint32_t now = micros();
  if (nextUs == 0) nextUs = now + SAMPLE_PERIOD_US;
  if ((int32_t)(now - nextUs) < 0) return;
  nextUs += SAMPLE_PERIOD_US;
  if ((int32_t)(now - nextUs) > (int32_t)(4 * SAMPLE_PERIOD_US)) {
    nextUs = now + SAMPLE_PERIOD_US;
  }
  if (!g_running) return;

  uint16_t adcV = readAdcAvg(ADC_PIN_V, N_AVG);
  uint16_t adcI = readAdcAvg(ADC_PIN_I, N_AVG);
  uint32_t sampleUs = micros();

  float dtS = (float)SAMPLE_PERIOD_US / 1000000.0f;
  float vAdc = adcToVolts(adcV);
  float iAdc = adcToVolts(adcI);

  if (adcV <= 1 || adcV >= 4094 || adcI <= 1 || adcI >= 4094) {
    g_cycleFlags |= FLAG_ADC_SAT;
  }

  float alpha = dtS / max(1e-6f, OFFSET_TAU_S);
  if (alpha > 1.0f) alpha = 1.0f;
  g_vOffset += alpha * (vAdc - g_vOffset);
  g_iOffset += alpha * (iAdc - g_iOffset);

  float vInst = (vAdc - g_vOffset) * V_SCALE_ENG_PER_VOLT;
  float iInst = (iAdc - g_iOffset) * I_SCALE_ENG_PER_VOLT;
  float vAcAdc = vAdc - g_vOffset;

  static const float outlierStepV = autoOutlierStep(V_NOMINAL_RMS * sqrtf(2.0f) * 5.0f, FREQ_REF_HZ, SAMPLE_RATE_HZ);
  static const float outlierStepI = autoOutlierStep(I_NOMINAL_RMS * sqrtf(2.0f) * 10.0f, FREQ_REF_HZ, SAMPLE_RATE_HZ);
  bool outlier = false;
  if (g_havePrev) {
    if (fabsf(vInst - g_vPrev) > outlierStepV) {
      vInst = g_vPrev;
      outlier = true;
    }
    if (fabsf(iInst - g_iPrev) > outlierStepI) {
      iInst = g_iPrev;
      outlier = true;
    }
  }
  g_vPrev = vInst;
  g_iPrev = iInst;
  g_havePrev = true;
  if (outlier) g_cycleFlags |= FLAG_OUTLIER;

  float zcHystAdc = max(0.002f, ZC_HYST_REAL / max(1e-9f, fabsf(V_SCALE_ENG_PER_VOLT)));
  int8_t newState = g_zcState;
  if (vAcAdc < -zcHystAdc) newState = -1;
  else if (vAcAdc > zcHystAdc) newState = 1;

  uint8_t cycleUpdate = 0;
  if (g_zcState == -1 && newState == 1) {
    closeCycle(sampleUs);
    resetCycle(sampleUs);
    cycleUpdate = 1;
  }
  g_zcState = newState;

  appendCycleSample(vInst, iInst);
  logSample(sampleUs, adcV, adcI, vInst, iInst, cycleUpdate);
  g_seq++;
}

static void printStatus() {
  Serial.printf(
    "STATUS running=%u seq=%lu cycles=%lu log=%u V1=%.6f I1=%.6f f=%.3f valid=%u "
    "oc=%s dist=%s voltage=%s relay=%u qf=%u\n",
    g_running ? 1 : 0,
    (unsigned long)g_seq,
    (unsigned long)g_cycleId,
    g_logCount,
    g_v1Mag,
    g_i1Mag,
    g_fEst,
    g_fourierValid,
    ocTripCode(),
    distTripCode(),
    voltageTripCode(),
    (g_ocTrip || g_distTrip || g_uvTrip || g_ovTrip) ? 1 : 0,
    g_lastQualityFlags
  );
}

static void printHelp() {
  Serial.println("Commands:");
  Serial.println("  h/help       show commands");
  Serial.println("  start        resume sampling/protection");
  Serial.println("  stop         pause sampling/protection");
  Serial.println("  status       print current state");
  Serial.println("  dump         dump compact RAM log as essential CSV");
  Serial.println("  clear        clear RAM log");
  Serial.println("  header       print CSV header");
  Serial.println("  stream on    stream one CSV row per completed cycle");
  Serial.println("  stream off   stop cycle CSV streaming");
  Serial.println("  resettrip    clear latched trips and relay");
}

static void handleSerial() {
  if (!Serial.available()) return;
  String line = Serial.readStringUntil('\n');
  line.trim();
  line.toLowerCase();
  if (line.length() == 0) return;

  if (line == "h" || line == "help") {
    printHelp();
  } else if (line == "start") {
    g_running = true;
    Serial.println("OK start");
  } else if (line == "stop") {
    g_running = false;
    Serial.println("OK stop");
  } else if (line == "status") {
    printStatus();
  } else if (line == "dump") {
    dumpLogCsv();
  } else if (line == "clear") {
    clearLog();
    Serial.println("OK clear");
  } else if (line == "header") {
    printCsvHeader();
  } else if (line == "stream on") {
    g_streamCycleCsv = true;
    g_csvHeaderPrinted = false;
    Serial.println("OK stream=on");
  } else if (line == "stream off") {
    g_streamCycleCsv = false;
    Serial.println("OK stream=off");
  } else if (line == "resettrip") {
    resetTrips();
    Serial.println("OK resettrip");
  } else {
    Serial.printf("ERR unknown_cmd=%s\n", line.c_str());
  }
}

void setup() {
  Serial.begin(SERIAL_BAUD);
  Serial.setTimeout(50);
  delay(300);

  analogReadResolution(12);
  analogSetPinAttenuation(ADC_PIN_V, ADC_11db);
  analogSetPinAttenuation(ADC_PIN_I, ADC_11db);

  pinMode(RELAY_PIN, OUTPUT);
  setRelay(false);

  g_distZ1Circle = mhoCircle(g_distZ1Ohm, DIST_LINE_ANGLE_DEG);
  g_distZ2Circle = mhoCircle(g_distZ2Ohm, DIST_LINE_ANGLE_DEG);

  Serial.printf(
    "READY_EMBEDDED_RX baud=%lu fs=%lu log_capacity=%u relay_pin=%d v_scale=%.6f i_scale=%.6f\n",
    (unsigned long)SERIAL_BAUD,
    (unsigned long)SAMPLE_RATE_HZ,
    LOG_CAPACITY,
    RELAY_PIN,
    V_SCALE_ENG_PER_VOLT,
    I_SCALE_ENG_PER_VOLT
  );
  printHelp();
}

void loop() {
  handleSerial();
  processSample();
}
