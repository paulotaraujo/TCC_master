static float wrapAngleDeg(float angleDeg) {
  float wrapped = fmodf(angleDeg + 180.0f, 360.0f);
  if (wrapped < 0.0f) wrapped += 360.0f;
  wrapped -= 180.0f;
  if (wrapped == -180.0f) return 180.0f;
  return wrapped;
}

static float adcToVolts(uint16_t adc) {
  return ((float)adc / ADC_MAX) * ADC_VREF;
}

static float autoOutlierStep(float ampPeak, float freqHz, float sampleRateHz) {
  float fs = max(1.0f, sampleRateHz);
  float f = max(1.0f, freqHz);
  float a = max(1.0f, fabsf(ampPeak));
  float maxStep = a * (2.0f * PI * f) / fs;
  return max(0.8f, 6.0f * maxStep);
}

static uint16_t readAdcAvg(int pin, int n) {
  uint32_t acc = 0;
  for (int i = 0; i < n; ++i) acc += analogRead(pin);
  uint32_t avg = acc / (uint32_t)n;
  if (avg > 4095) avg = 4095;
  return (uint16_t)avg;
}

static Phasor fundamentalPhasorRms(const float *samples, uint16_t n) {
  Phasor out;
  if (n < 2) return out;

  float re = 0.0f;
  float im = 0.0f;
  for (uint16_t k = 0; k < n; ++k) {
    float theta = (2.0f * PI * (float)k) / (float)n;
    re += samples[k] * cosf(theta);
    im -= samples[k] * sinf(theta);
  }

  float peakMag = (2.0f / (float)n) * sqrtf(re * re + im * im);
  out.mag = peakMag / sqrtf(2.0f);
  out.angleDeg = wrapAngleDeg(atan2f(im, re) * 180.0f / PI);
  return out;
}

static MhoCircle mhoCircle(float reachOhm, float lineAngleDeg) {
  float angleRad = lineAngleDeg * PI / 180.0f;
  MhoCircle circle;
  circle.radius = 0.5f * reachOhm;
  circle.centerR = circle.radius * cosf(angleRad);
  circle.centerX = circle.radius * sinf(angleRad);
  return circle;
}

static bool mhoOperates(float rOhm, float xOhm, float reachOhm, float lineAngleDeg) {
  MhoCircle c = mhoCircle(reachOhm, lineAngleDeg);
  float dr = rOhm - c.centerR;
  float dx = xOhm - c.centerX;
  return (dr * dr + dx * dx) <= (c.radius * c.radius);
}

static void setRelay(bool trip) {
  digitalWrite(RELAY_PIN, trip == RELAY_ACTIVE_HIGH ? HIGH : LOW);
}

